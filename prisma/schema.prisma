generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String          @id @default(uuid()) @map("id_3f8a9c1e_6d2b_4b7a_9c5e_2f1d8a7b3c4e") @db.VarChar(56) // Primary key, unique identifier menggunakan UUID
  username  String          @unique @map("username_a1d7e3f2_9b4c_4e6a_8d1f_5c2b7a9e3d6f") @db.VarChar(50) // Username unik untuk login atau identifikasi user
  email     String          @unique @map("email_7c2e9a1b_5d4f_4a8c_b3e1_6f9d2c7a8b5e") @db.VarChar(150) // Email unik untuk komunikasi dan autentikasi
  avatar    String?         @map("avatar_d4a1b9c7_3e5f_4c2a_8d6b_1f7e9a2c3d5b") // URL avatar kecil (opsional)
  image     String?         @map("image_9e3b7c1d_2a5f_4d8c_b6a1_3f2e7c9a4d5b") // URL gambar profil utama (opsional)
  role      UserRole        @default(ADMIN) @map("role_b7d2a4e9_6c1f_4a3e_9d5b_2c8a7f1e3d6c") // Role user (authorization), default ADMIN
  providers LoginProvider[] @default([]) @map("providers_2a9f3d7c_5e1b_4c6a_8d2f_9b7c1e3a5d4f") // Daftar metode login (Google, Email, dll)

  settings      Setting? // Relasi ke pengaturan user (opsional, 1-1)
  customer      Customer? // Relasi jika user adalah customer
  admin         Admin? // Relasi jika user adalah admin
  notifications Notification[] // Daftar notifikasi milik user
  subscriptions Subscription[] // Subscription Web Push

  createdAt DateTime @default(now()) @map("created_at_f1c7a9d3_2e5b_4a8c_9d6f_3b2a7c1e5d4f") @db.Timestamptz() // Waktu pembuatan data
  updatedAt DateTime @updatedAt @map("updated_at_6b2e7c9a_4d1f_4a3e_8c5b_7d9a2f1e3c6b") @db.Timestamptz() // Waktu terakhir update otomatis

  @@index([id], name: "idx_user_id_e3a7d1c9_5b2f_4c6a_9d8e_1f7a3c2b5d4e") // Index untuk pencarian berdasarkan id
  @@index([username], name: "idx_user_username_4d9a2c7e_1b5f_4a3c_8e6d_2f7a9c1e3b5d") // Index untuk username
  @@index([email], name: "idx_user_email_c2a7e9d1_3f5b_4d6a_8c9e_7b1a2c3d5e4f") // Index untuk email
  @@index([avatar], name: "idx_user_avatar_8f3a1c7d_5e2b_4a9c_b6d1_3c7e2f9a5d4b") // Index untuk avatar (jika sering query)
  @@index([image], name: "idx_user_image_5c1e7a9d_3b2f_4d6a_8c9e_1f7a3d2b5c4e") // Index untuk image
  @@index([role], name: "idx_user_role_a9c3e7d1_5f2b_4a6c_8d9e_3b1a7c2d5e4f") // Index untuk filtering berdasarkan role
  @@index([providers], name: "idx_user_providers_9c3e1a7d_5b2f_4d6a_8c9e_2f7a1b3c5d4e") // Index untuk provider login
  @@index([createdAt], name: "idx_user_created_at_1d7a9c3e_5b2f_4c6a_8e9d_3f7a2c1b5d4e") // Index untuk sorting/filter waktu dibuat
  @@index([updatedAt], name: "idx_user_updated_at_7a3c9e1d_5b2f_4d6a_8c9e_2f1a7b3c5d4e") // Index untuk sorting/filter waktu update
  @@map("users_3e1a7c9d_5b2f_4a6c_8d9e_2f7b1c3a5d4e") // Nama tabel di database
}

model Setting {
  id           String   @id @default(uuid()) @map("id_2b7f9c1e_4a3d_4e8b_9c6a_1f5d3b7e2c9a") @db.VarChar(56) // Primary key, unique identifier menggunakan UUID
  theme        Theme    @default(SYSTEM) @map("theme_8c3e1a7d_5f2b_4d6a_9c9e_2f1a7b3c5d4e") // Tema tampilan user (SYSTEM, LIGHT, DARK)
  language     Language @default(ID) @map("language_4a9d2c7e_1b5f_4a3c_8e6d_3f7a9c1e2b5d") // Bahasa antarmuka user (ID, EN, dll)
  notification Boolean  @default(false) @map("notification_6e1c9a3d_2f5b_4d7a_8c1e_9b3a2f7c5d4e") @db.Boolean // Status notifikasi aktif/nonaktif

  userId String @unique @map("user_id_3d7a1c9e_5b2f_4a6c_8d9e_1f7b3c2a5d4e") @db.VarChar(56) // Foreign key ke tabel users
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "relation_settings_user_1f7b3c2a5d4e")

  createdAt DateTime @default(now()) @map("created_at_9c1e7a3d_5b2f_4d6a_8c9e_2f1a7b3c5d4e") @db.Timestamptz() // Waktu pembuatan data
  updatedAt DateTime @updatedAt @map("updated_at_1a7c9e3d_5b2f_4d6a_8c9e_3f7a2b1c5d4e") @db.Timestamptz() // Waktu terakhir update otomatis

  @@index([id], name: "idx_settings_id_2f7a3b1c5d4e") // Index untuk pencarian berdasarkan id
  @@index([theme], name: "idx_settings_theme_1f7a2b3c5d4e") // Index untuk filtering berdasarkan tema
  @@index([language], name: "idx_settings_language_7f1a3b2c5d4e") // Index untuk filtering berdasarkan bahasa
  @@index([notification], name: "idx_settings_notification_2f7a1b3c5d4e") // Index untuk filtering status notifikasi
  @@index([userId], name: "idx_settings_user_id_5f7a2b1c3d4e") // Index untuk relasi ke user
  @@index([createdAt], name: "idx_settings_created_at_1f7a3b2c5d4e") // Index untuk sorting/filter waktu dibuat
  @@index([updatedAt], name: "idx_settings_updated_at__7f2a1b3c5d4e") // Index untuk sorting/filter waktu update
  @@map("settings_6c9e3a1d_5b2f_4d7a_8c9e_2f7a1b3c5d4e") // Nama tabel di database
}

model Subscription {
  id        String  @id @default(uuid()) @map("id_8f2a1b3c_5d4e_4d6a_9c9e_1f7a3b2c5d4e") @db.VarChar(56) // Primary key, unique identifier menggunakan UUID
  endpoint  String  @unique @map("endpoint_3c7e1a9d_5b2f_4d6a_8c9e_2f7a1b3c5d4e") @db.Text // URL endpoint dari browser Push API
  p256dh    String  @map("p256dh_9a1e7c3d_5b2f_4d6a_8c9e_1f7a3b2c5d4e") @db.Text // Public key untuk enkripsi pesan push
  auth      String  @map("auth_4d2c9a7e_1b5f_4a3c_8e6d_3f7a9c1e2b5d") @db.Text // Auth secret untuk verifikasi subscription
  userAgent String? @map("user_agent_7e3a1c9d_5b2f_4d6a_8c9e_2f1a7b3c5d4e") @db.VarChar(255) // Informasi browser/perangkat pengguna (opsional)

  userId String @map("user_id_2c9a7e1d_5b3f_4d6a_8c9e_7f1a2b3c5d4e") @db.VarChar(56) // Foreign key ke tabel users
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "relation_subscription_user_1f7a3b2c5d4e")

  createdAt DateTime @default(now()) @map("created_at_8e1c3a7d_5b2f_4d6a_9c9e_2f7a1b3c5d4e") @db.Timestamptz() // Waktu pembuatan data
  updatedAt DateTime @updatedAt @map("updated_at_1a3e9c7d_5b2f_4d6a_8c9e_3f7a2b1c5d4e") @db.Timestamptz() // Waktu terakhir update otomatis

  @@index([id], name: "idx_subscription_id_5b2f4d6a_8c9e_2f7a1b3c5d4e") // Index untuk pencarian berdasarkan id
  @@index([endpoint], name: "idx_subscription_endpoint_3c7e1a9d_5b2f4d6a_8c9e") // Index untuk pencarian berdasarkan endpoint
  @@index([userId], name: "idx_subscription_user_id_9a1e7c3d_5b2f_4d6a_8c9e") // Index untuk relasi ke user
  @@index([userAgent], name: "idx_subscription_user_agent_4d2c9a7e_1b5f4a3c") // Index untuk filtering berdasarkan perangkat
  @@index([createdAt], name: "idx_subscription_created_at_7e3a1c9d_5b2f4d6a") // Index untuk sorting/filter waktu dibuat
  @@index([updatedAt], name: "idx_subscription_updated_at_2f7a1b3c_5d4e6a8c") // Index untuk sorting/filter waktu update
  @@map("subscriptions_6d2e9a1c_5b3f_4d7a_8c9e_2f1a7b3c5d4e") // Nama tabel di database
}

model Notification {
  id          String               @id @default(uuid()) @map("id_3c7e1a9d_5b2f_4d6a_8c9e_2f7a1b3c5d4e") @db.VarChar(56) // Primary key, unique identifier menggunakan UUID
  type        NotificationType     @map("type_9a1e7c3d_5b2f_4d6a_8c9e_1f7a3b2c5d4e") // Tipe notifikasi (INFO, WARNING, ERROR, dll)
  category    String               @map("category_4d2c9a7e_1b5f_4a3c_8e6d_3f7a9c1e2b5d") @db.VarChar(100) // Kategori notifikasi untuk pengelompokan
  title       String               @map("title_7e3a1c9d_5b2f_4d6a_8c9e_2f1a7b3c5d4e") @db.VarChar(150) // Judul notifikasi
  message     String               @map("message_2c9a7e1d_5b3f_4d6a_8c9e_7f1a2b3c5d4e") @db.Text // Isi pesan notifikasi
  actionUrl   String?              @map("action_url_8e1c3a7d_5b2f_4d6a_9c9e_2f7a1b3c5d4e") @db.VarChar(255) // URL tujuan jika notifikasi diklik (opsional)
  actionLabel String?              @map("action_label_5b3d9c1e_7a2f_4d6a_8c9e_1f7a3b2c5d4e") @db.VarChar(50) // Label tombol aksi notifikasi (opsional)
  priority    NotificationPriority @default(NORMAL) @map("priority_1a7c9e3d_5b2f_4d6a_8c9e_3f7a2b1c5d4e") // Prioritas notifikasi (LOW, NORMAL, HIGH)
  isRead      Boolean              @default(false) @map("is_read_6d2e9a1c_5b3f_4d7a_8c9e_2f1a7b3c5d4e") @db.Boolean // Status apakah notifikasi sudah dibaca
  readAt      DateTime?            @map("read_at_9c1e3a7d_5b2f_4d6a_8c9e_7f2a1b3c5d4e") @db.Timestamptz() // Waktu notifikasi dibaca (opsional)
  relatedType String?              @map("related_type_3e7a1c9d_5b2f_4d6a_8c9e_1f7a3b2c5d4e") @db.VarChar(50) // Tipe entitas terkait notifikasi (opsional)

  relatedId String? @map("related_id_7b1a3c9e_5d2f_4d6a_8c9e_2f7a1b3c5d4e") @db.VarChar(56) // ID entitas terkait notifikasi (opsional)
  userId    String? @map("user_id_4c9e1a3d_5b2f_4d6a_8c9e_3f7a2b1c5d4e") @db.VarChar(56) // Foreign key ke tabel users (opsional)
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "relation_notification_user_3f7a2b1c5d4e")

  createdAt DateTime @default(now()) @map("created_at_2a3c7e9d_5b1f_4d6a_8c9e_7f2a1b3c5d4e") @db.Timestamptz() // Waktu pembuatan data
  updatedAt DateTime @updatedAt @map("updated_at_5e9c1a3d_7b2f_4d6a_8c9e_1f7a3b2c5d4e") @db.Timestamptz() // Waktu terakhir update otomatis

  @@index([id], name: "idx_notification_id_8d1e9a3c_5b2f_4d6a_8c9e_2f7a1b3c5d4e") // Index untuk pencarian berdasarkan id
  @@index([type], name: "idx_notification_type_3c7a1e9d_5b2f_4d6a_8c9e_7f1a2b3c5d4e") // Index untuk filtering berdasarkan tipe
  @@index([category], name: "idx_notification_category_9e1c3a7d_5b2f_4d6a_8c9e_2f7a1b3c5d4e") // Index untuk filtering berdasarkan kategori
  @@index([title], name: "idx_notification_title_4a7c9e1d_5b2f_4d6a_8c9e_1f7a3b2c5d4e") // Index untuk pencarian berdasarkan judul
  @@index([message], name: "idx_notification_message_7d3e1a9c_5b2f_4d6a_8c9e_3f7a2b1c5d4e") // Index untuk pencarian berdasarkan isi pesan
  @@index([actionUrl], name: "idx_notification_action_url_7f1a2b3c5d4e") // Index untuk action URL
  @@index([actionLabel], name: "idx_notification_action_label_2f7a1b3c5d4e") // Index untuk action label
  @@index([priority], name: "idx_notification_priority_7f2a1b3c5d4e") // Index untuk filtering berdasarkan prioritas
  @@index([isRead], name: "idx_notification_is_read_2f7a1b3c5d4e") // Index untuk filtering status baca
  @@index([readAt], name: "idx_notification_read_at_1f7a3b2c5d4e") // Index untuk sorting/filter waktu dibaca
  @@index([relatedType], name: "idx_notification_related_type_7f2a1b3c5d4e") // Index untuk filtering berdasarkan tipe relasi
  @@index([relatedId], name: "idx_notification_related_id_2f7a1b3c5d4e") // Index untuk pencarian berdasarkan ID relasi
  @@index([userId], name: "idx_notification_user_id_4e3a9c1d_5b2f_4d6a_8c9e_1f7a3b2c5d4e") // Index untuk relasi ke user
  @@index([createdAt], name: "idx_notification_created_at_2f7a1b3c5d4e") // Index untuk sorting/filter waktu dibuat
  @@index([updatedAt], name: "idx_notification_updated_at_7f1a2b3c5d4e") // Index untuk sorting/filter waktu update
  @@map("notifications_1a3e9c7d_5b2f_4d6a_8c9e_2f7a1b3c5d4e") // Nama tabel di database
}

model Admin {
  id            String         @id @default(uuid()) @map("id_6c1e9a3d_7b2f_4d6a_8c9e_2f7a1b3c5d4e") @db.VarChar(56) // Primary key, unique identifier menggunakan UUID
  fullName      String         @map("full_name_3a7e1c9d_5b2f_4d6a_8c9e_1f7a3b2c5d4e") @db.VarChar(150) // Nama lengkap admin
  nationalId    String         @unique @map("national_id_9d2c7a1e_5b3f_4d6a_8c9e_7f1a2b3c5d4e") @db.VarChar(20) // Nomor Induk Kependudukan (NIK) unik admin
  birthPlace    String?        @map("birth_place_4e1a3c9d_5b2f_4d6a_8c9e_2f7a1b3c5d4e") @db.VarChar(100) // Tempat lahir admin (opsional)
  birthDate     DateTime?      @map("birth_date_7c9e1a3d_5b2f_4d6a_8c9e_3f7a2b1c5d4e") @db.Date // Tanggal lahir admin (opsional)
  gender        Gender?        @map("gender_2a5c9e1d_7b3f_4d6a_8c9e_1f7a3b2c5d4e") // Jenis kelamin admin (opsional)
  age           Int?           @map("age_8e3a1c7d_5b2f_4d6a_9c9e_2f7a1b3c5d4e") // Usia admin dalam tahun (opsional)
  phone         String?        @map("phone_1d7c9a3e_5b2f_4d6a_8c9e_7f2a1b3c5d4e") @db.VarChar(20) // Nomor telepon admin (opsional)
  email         String?        @map("email_5a3e1c9d_7b2f_4d6a_8c9e_2f7a1b3c5d4e") @db.VarChar(150) // Alamat email admin (opsional)
  address       String?        @map("address_9c1e7a3d_5b2f_4d6a_8c9e_1f7a3b2c5d4e") @db.Text // Alamat lengkap admin (opsional)
  maritalStatus MaritalStatus? @map("marital_status_3e9a1c7d_5b2f_4d6a_8c9e_7f2a1b3c5d4e") // Status pernikahan admin (opsional)

  userId                String?             @unique @map("user_id_6d2a9c1e_5b3f_4d7a_8c9e_2f1a7b3c5d4e") @db.VarChar(56) // Foreign key ke tabel users (opsional)
  user                  User?               @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "relation_admin_user_2f1a7b3c5d4e")
  reports               Report[]
  reviewedApplications  CreditApplication[] @relation("ReviewedApplications")
  approvedApplications  CreditApplication[] @relation("ApprovedApplications")
  rejectedApplications  CreditApplication[] @relation("RejectedApplications")
  disbursedApplications CreditApplication[] @relation("DisbursedApplications")
  createdQuestions      InterviewQuestion[] @relation("CreatedQuestions")
  updatedQuestions      InterviewQuestion[] @relation("UpdatedQuestions")
  creditWorthinesses    CreditWorthiness[]

  createdAt DateTime @default(now()) @map("created_at_4b7e9c1a_5d2f_4d6a_8c9e_1f7a3b2c5d4e") @db.Timestamptz() // Waktu pembuatan data
  updatedAt DateTime @updatedAt @map("updated_at_8c3a1e9d_5b2f_4d6a_8c9e_7f2a1b3c5d4e") @db.Timestamptz() // Waktu terakhir update otomatis

  @@index([id], name: "idx_admin_id_1f7a3b2c5d4e") // Index untuk pencarian berdasarkan id
  @@index([fullName], name: "idx_admin_full_name_2f7a1b3c5d4e") // Index untuk pencarian berdasarkan nama lengkap
  @@index([nationalId], name: "idx_admin_national_id_7f2a1b3c5d4e") // Index untuk pencarian berdasarkan NIK
  @@index([birthPlace], name: "idx_admin_birth_place_2f7a1b3c5d4e") // Index untuk filtering berdasarkan tempat lahir
  @@index([birthDate], name: "idx_admin_birth_date_3f7a2b1c5d4e") // Index untuk sorting/filter tanggal lahir
  @@index([gender], name: "idx_admin_gender_7f1a2b3c5d4e") // Index untuk filtering berdasarkan jenis kelamin
  @@index([phone], name: "idx_admin_phone_2f7a1b3c5d4e") // Index untuk pencarian berdasarkan nomor telepon
  @@index([email], name: "idx_admin_email_1f7a3b2c5d4e") // Index untuk pencarian berdasarkan email
  @@index([address], name: "idx_admin_address_7f2a1b3c5d4e") // Index untuk pencarian berdasarkan alamat
  @@index([maritalStatus], name: "idx_admin_marital_status_2f7a1b3c5d4e") // Index untuk filtering berdasarkan status pernikahan
  @@index([userId], name: "idx_admin_user_id_1f7a3b2c5d4e") // Index untuk relasi ke user
  @@index([createdAt], name: "idx_admin_created_at_7f2a1b3c5d4e") // Index untuk sorting/filter waktu dibuat
  @@index([updatedAt], name: "idx_admin_updated_at_2f7a1b3c5d4e") // Index untuk sorting/filter waktu update
  @@map("admins_5b2f9c1e_7a3d_4d6a_8c9e_1f7a3b2c5d4e") // Nama tabel di database
}

model Customer {
  id               String          @id @default(uuid()) @map("id_7a3e1c9d_5b2f_4d6a_8c9e_2f7a1b3c5d4e") @db.VarChar(56) // Primary key, unique identifier menggunakan UUID
  fullName         String          @map("full_name_2c9e7a1d_5b3f_4d6a_8c9e_1f7a3b2c5d4e") @db.VarChar(150) // Nama lengkap customer
  nationalId       String          @unique @map("national_id_8e1a3c7d_5b2f_4d6a_9c9e_7f2a1b3c5d4e") @db.VarChar(20) // Nomor Induk Kependudukan (NIK) unik customer
  birthPlace       String?         @map("birth_place_4d7c9a1e_5b2f_4d6a_8c9e_3f7a2b1c5d4e") @db.VarChar(100) // Tempat lahir customer (opsional)
  birthDate        DateTime?       @map("birth_date_1e3a7c9d_5b2f_4d6a_8c9e_2f7a1b3c5d4e") @db.Date // Tanggal lahir customer (opsional)
  gender           Gender?         @map("gender_9c1e3a7d_5b2f_4d6a_8c9e_7f1a2b3c5d4e") // Jenis kelamin customer (opsional)
  age              Int?            @map("age_5a7e1c3d_9b2f_4d6a_8c9e_2f7a1b3c5d4e") // Usia customer dalam tahun (opsional)
  phone            String?         @map("phone_3d9c7a1e_5b2f_4d6a_8c9e_1f7a3b2c5d4e") @db.VarChar(20) // Nomor telepon customer (opsional)
  email            String?         @map("email_6e1a9c3d_5b2f_4d7a_8c9e_7f2a1b3c5d4e") @db.VarChar(150) // Alamat email customer (opsional)
  address          String?         @map("address_2a7c1e9d_5b3f_4d6a_8c9e_2f7a1b3c5d4e") @db.Text // Alamat lengkap customer (opsional)
  maritalStatus    MaritalStatus?  @map("marital_status_8d3e9a1c_5b2f_4d6a_8c9e_1f7a3b2c5d4e") // Status pernikahan customer (opsional)
  spouseName       String?         @map("spouse_name_3d7c1a9e_5b2f_4d6a_8c9e_1f7a3b2c5d4e") @db.VarChar(150) // Nama pasangan customer (opsional)
  spouseBirthDate  DateTime?       @map("spouse_birth_date_9e1c3a7d_5b2f_4d6a_8c9e_7f2a1b3c5d4e") @db.Date // Tanggal lahir pasangan customer (opsional)
  motherName       String?         @map("mother_name_4a9e7c1d_5b2f_4d6a_8c9e_3f7a2b1c5d4e") @db.VarChar(150) // Nama ibu kandung customer (opsional)
  employmentType   EmploymentType? @map("employment_type_4c1a7e9d_5b2f_4d6a_9c9e_3f7a2b1c5d4e") // Jenis pekerjaan customer (opsional)
